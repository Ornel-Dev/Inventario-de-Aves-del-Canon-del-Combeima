    <style>
      body {
        margin: 0 0 9rem 0;
      }
      .contenedor-principal {
        margin: 2rem auto;
      }
      .hero {
        background-color: var(--verde-oscuro);
        width: 100%;
        height: 40rem;
        display: flex;
        justify-content: center;
        align-items: center;
        /* border-bottom-left-radius:2rem ; */
        /* border-bottom-right-radius: 1.6rem; */
      }
      .hero h1 {
        font-size: 4rem;
        color: #ffff;
        font-weight: bold;
      }
      h2 {
        text-align: center;
        font-size: 2rem;
        margin-bottom: 2rem;
        color: var(--verde-oscuro);
      }
      .formulario {
        margin-bottom: 3rem;
      }
      .formulario-contenido {
        display: flex;
        flex-direction: column;
      }
      form {
        font-size: 1.4rem;
      }
      legend {
        font-size: 1.6rem;
      }

      fieldset {
        display: flex;
        flex-direction: column;
        width: 100%;
        border-radius: 1rem;
        margin: 1rem 0;
        outline: none;
        border: 0.1rem solid var(--verde-oscuro);
      }
      .form-grupo {
        display: flex;
        margin: 1rem;
        gap: 0.5rem;
        align-items: center;
      }
      .no-center {
        align-items: flex-start;
      }
      input {
        width: 100%;
        border-radius: 0.5rem;
        padding: 0.3rem;
        border: 0.1rem solid #cccc;
        outline: none;
      }
      select{
        border-radius: .5rem;
      }
      input:focus,
      select:focus,
      textarea:focus {
        border: 0.1rem solid #027007;
        box-shadow: 0 0 0 3px rgba(75, 229, 70, 0.2);
      }

      select {
        width: 73%;
        outline: none;
      }
      textarea {
        width: 100%;
        border-radius: 0.5rem;
        outline: none;
      }

      /* From Uiverse.io by KINGFRESS */
      button {
        font-family: Arial, Helvetica, sans-serif;
        font-weight: bold;
        color: white;
        width: 40%;
        margin: auto auto;
        background-color: var(--verde-oscuro);
        padding: 1em 2em;
        border: none;
        border-radius: 0.6rem;
        position: relative;
        cursor: pointer;
        overflow: hidden;
      }

      button span:not(:nth-child(6)) {
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        height: 30px;
        width: 30px;
        background-color: var(--verde-oliva);
        border-radius: 50%;
        transition: 0.6s ease;
      }

      button span:nth-child(6) {
        position: relative;
      }

      button span:nth-child(1) {
        transform: translate(-4.3em, -5em);
      }

      button span:nth-child(2) {
        transform: translate(-7em, 2.3em);
      }

      button span:nth-child(3) {
        transform: translate(-0.8em, 2.8em);
      }

      button span:nth-child(4) {
        transform: translate(4.5em, 2.4em);
      }

      button span:nth-child(5) {
        transform: translate(4.5em, -4.8em);
      }

      button:hover span:not(:nth-child(6)) {
        transform: translate(-50%, -50%) scale(4);
        transition: 1.5s ease;
        color: var(--verde-oscuro);
      }

      .mensaje {
        text-align: center;
        font-size: 1.2rem;
        color: #007c06;
        margin: 1rem auto;
      }
      .hide {
        opacity: 0;
      }

      /* Variables de color y reset básico */
      :root {
        --bg-card: #123618; /* Fondo de la tarjeta */
        --text-primary: #f8fafc;
        --text-secondary: #d0d3d0;
        --accent-color: #00ccff; /* Azul brillante para destacar */
        --whatsapp-color: #25d366;
      }

      /* Tarjeta Principal */
      .card {
        background-color: var(--bg-card);
        border-radius: 20px;
        width: 100%;
        max-width: 350px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease;
      }

      .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
      }

      /* Cabecera con efecto de desvanecimiento hacia el fondo */
      .card-header {
        position: relative;
        width: 100%;
        height: 20rem;
      }

      .card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        /* Máscara que hace que la imagen se vuelva transparente abajo */
        -webkit-mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 1) 65%,
          rgba(0, 0, 0, 0) 100%
        );
        mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 1) 65%,
          rgba(0, 0, 0, 0) 100%
        );
      }

      /* Cuerpo de la tarjeta */
      .card-body {
        padding: 0 24px 24px 24px;
        text-align: center;
      }

      .card-name {
        color: var(--text-primary);
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 4px;
      }

      .card-role {
        color: var(--accent-color);
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 16px;
      }

      .card-description {
        color: var(--text-secondary);
        font-size: 0.95rem;
        line-height: 1.5;
        margin-bottom: 24px;
      }

      /* Redes Sociales */
      .social-links {
        display: flex;
        justify-content: center;
        gap: 16px;
        margin-bottom: 24px;
      }

      .social-icon {
        color: var(--text-secondary);
        font-size: 1.2rem;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background-color: rgba(255, 255, 255, 0.05);
        display: flex;
        justify-content: center;
        align-items: center;
        text-decoration: none;
        transition: all 0.3s ease;
      }

      .social-icon:hover {
        color: var(--text-primary);
        background-color: rgba(255, 255, 255, 0.15);
        transform: scale(1.1);
      }

      /* Botón de WhatsApp */
      .btn-whatsapp {
        width: 100%;
        background-color: var(--whatsapp-color);
        color: #ffffff;
        border: none;
        padding: 12px 20px;
        font-size: 1rem;
        font-weight: 600;
        border-radius: 10px;
        cursor: pointer;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        transition:
          background-color 0.3s ease,
          transform 0.2s ease;
      }

      .btn-whatsapp:hover {
        background-color: #20ba5a;
      }

      .btn-whatsapp:active {
        transform: scale(0.98);
      }
.tarjetas{
      width: 100%;
          display: flex;
          flex-direction: column;
          justify-content: center;
          align-items: center;

          gap: 2rem;
}
      @media (min-width: 768px) {
        .tres-caja {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 3rem;
        }
        .tarjetas {
          flex-direction: row;
        }
       html{
        font-size: 60%;
       }
        }
      @media (min-width: 1440px) {
       html{
        font-size: 100%;
       }
       input, select{
        height: 3rem;
       }
      }
    </style>
    <script>
      const form = document.getElementById("form") as HTMLFormElement | null;
      const submitBtn = form?.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement | null;
      const msjConfirm = document.getElementById(
        "mensajeform",
      ) as HTMLFormElement | null;

      if (form) {
        form.addEventListener("submit", async (e) => {
          e.preventDefault();

          const formData = new FormData(form);
          formData.append("access_key", "29ae155d-1093-4a8d-91a7-f3badd903112");

          if (submitBtn) {
            submitBtn.disabled = true;
          }

          try {
            const response = await fetch("https://api.web3forms.com/submit", {
              method: "POST",
              body: formData,
            });

            const data = await response.json();

            if (response.ok) {
              if (msjConfirm) {
                msjConfirm?.classList.remove("hide");
                setTimeout(() => {
                  msjConfirm?.classList.add("hide");
                }, 3000);
              }

              form.reset();
            } else {
              alert("Error: " + data.message);
            }
          } catch (error) {
            alert(
              "Lo sentimos ocurrio un error al enviar el mensaje, por favor reintenta.",
            );
          } finally {
            if (submitBtn) {
              submitBtn.disabled = false;
            }
          }
        });
      }
    </script>
  </body>
</html>
