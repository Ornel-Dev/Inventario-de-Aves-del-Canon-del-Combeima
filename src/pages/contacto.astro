  <body>
    <Header />
    <div class="hero">
      <h1>Contactanos</h1>
    </div>

    <main class="contenedor-principal tres-caja">
      <div class="formulariocaja">
        <h2>Llena el formulario y nos comunicaremos contigo</h2>
        <div class="formulario">
          <form
            id="form"
            class="formulario-contenido"
            action="https://api.web3forms.com/submit"
            method="post"
          >
            <fieldset>
              <legend>¿Quien eres?</legend>

              <div class="form-grupo">
                <label for="nombre">Nombre</label>
                <input
                  type="text"
                  name="nombre"
                  id="nombre"
                  placeholder="Tu nombre"
                  required
                />
              </div>
            </fieldset>

            <fieldset>
              <legend>¿Como te contactamos?</legend>
              <div class="form-grupo">
                <label for="celular">Celular</label>
                <input
                  type="tel"
                  name="celular"
                  id="celular"
                  placeholder="Ej: 302 1235600"
                  required
                />
              </div>
              <div class="form-grupo">
                <label for="correo">Correo</label>
                <input
                  type="email"
                  name="correo"
                  id="correo"
                  placeholder="hola@gmail.com"
                />
              </div>
            </fieldset>
            <fieldset>
              <legend>¿En qué estás interesado?</legend>
              <div class="form-grupo">
                <label for="interes">Me interesa</label>
                <select name="interes" id="interes" required>
                  <option value="" disabled selected hidden
                    >Selecciona la opción de tu interés</option
                  >

                  <optgroup label="Viajes">
                    <option value="v-cascada-plata"
                      >Hacer la ruta de la cascada La Plata</option
                    >
                    <option value="v-ruta-fruta"
                      >Hacer la ruta de La Fruta</option
                    >
                    <option value="v-termales-rancho"
                      >Hacer la ruta de los termales El Rancho</option
                    >
                    <option value="v-otros">Hacer otros viajes y rutas</option>
                  </optgroup>

                  <optgroup label="Desarrollo Web">
                    <option value="dw-pagina-empresa"
                      >Tener una página web para mi empresa/emprendimiento</option
                    >
                    <option value="dw-app-similar"
                      >Desarrollar una app web similar a esta</option
                    >
                    <option value="dw-aprender">Aprender desarrollo Web</option>
                    <option value="dw-otro">(Tengo otro interés)</option>
                  </optgroup>
                </select>
              </div>
              <div class="form-grupo no-center">
                <label for="mensaje">Mensaje</label>
                <textarea
                  name="mensaje"
                  id="mensaje"
                  rows="4"
                  maxlength="500"
                  placeholder="Me gustaría..."></textarea>
              </div>
            </fieldset>

            <!-- From Uiverse.io by KINGFRESS -->

            <button type="submit">
              <span class="circle1"></span>
              <span class="circle2"></span>
              <span class="circle3"></span>
              <span class="circle4"></span>
              <span class="circle5"></span>
              <span class="text">Enviar</span>
            </button>

            <p class="mensaje hide" id="mensajeform">
              Gracias por enviar el formulario. Nos comunicaremos contigo en
              brevedad
            </p>
          </form>
        </div>
      </div>

      <div class="tarjetas-caja">
