    }
    .autor img {
      border-radius: 50%;
      width: 4rem;
      height: 4rem;
    }
    strong {
      font-weight: bold;
    }

    /* Flujo de datos (Diagrama de texto) */
    .data-flow {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      background: #fdfaf6;
      border: 0.1rem dashed var(--accent-color);
      padding: 2rem;
      border-radius: 0.8rem;
      margin: 2rem 0;
      font-weight: bold;
      text-align: center;
    }

    .data-flow span.arrow {
      color: var(--verde-oscuro);
      font-size: 1.2rem;
    }

    /* Responsividad */
    @media (max-width: 600px) {
      .data-flow {
        flex-direction: column;
      }
      .data-flow span.arrow {
        transform: rotate(90deg);
      }
    }

    .cta-box {
      background-color: #eaf2eb;
      font-size: 1.3rem;
      border-left: 5px solid var(--verde-oscuro);
      padding: 2rem;
      margin-top: 3rem;
      border-radius: 0 0.5rem 0.5rem 0;
      font-style: italic;
    }
  </style>
