      background-size: cover;
      height: 80vh;
      width: 100%;
      background-repeat: no-repeat;
      display: flex;
      align-items: end;
      color: #ffff;
    }
    .hero h1 {
      margin: 3rem auto;
      width: 90%;
    }
    p,
    li {
      font-size: 1.6rem;
      color: var(--gris-parrafos);
    }

    .autor {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin: 2rem 0;
    }
    .nombre {
      font-weight: bold;
    }
    .autor p,
    .nombre {
