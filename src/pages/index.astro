---
import Header from "../componentes/Header.astro";
import Btnendemica from "../componentes/btn-endemica.astro";
import Btnaves from "../componentes/btn-aves.astro";
import Ruta from "../componentes/rutas-targ.astro";
import Footer from "../componentes/footer.astro";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans+Flex:opsz,wght@6..144,1..1000&family=Google+Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&family=Lexend:wght@100..900&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"/>
    <link rel="stylesheet" href="/styles/style.css" />
    <link rel="manifest" href="/manifest.json" />
    <title>Áurea | Inventario de Aves del Cañon del Combeima</title>
  </head>
  <body>
    <!-- Usamos el componente como si fuera una etiqueta HTML personalizada -->
     
    <Header />

    <main>
      <section class="seccion-principal imagen-fondo">
        <div class="contenedor-principal contenido">

          <h1>Inventario de Aves del Cañon del Combeima</h1>
          <div>

          <Btnendemica />
          </div>

          <i>Colibrí Cabecicastaño<br>Anthocephala berlepschi</i>
        </div>
      </section>

      <section class="contenedor-principal rutas">
        <Btnaves />

        <div class="rutas-titulo">
          <h2>Rutas de avistamiento</h2>
          <a href="#">Ver Todas</a>
        </div>
        <div class="rutas">
          <Ruta />
        </div>
      </section>
      <!-- MENSAJE FLOTANTE -->
      <div id="pwa-floating-bar" class="barra-flotante">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
    <span style="font-size: 13px; font-weight: bold; letter-spacing: 0.5px;">Modo Offline</span>
    <span id="pwa-text-percentage" style="color: #2e7d32; font-weight: bold; font-size: 14px;">0%</span>
  </div>
  <div style="width: 100%; background: #222222; height: 6px; border-radius: 4px; overflow: hidden;">
    <div id="pwa-progress-fill" style="width: 0%; background: #2e7d32; height: 100%; transition: width 0.2s ease;"></div>
  </div>
  <p id="pwa-file-name" style="margin: 6px 0 0 0; font-size: 10px; color: #777777; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 230px;"></p>
</div>
      <footer>

        <Footer />
      </footer>
    </main>

  </body>
    <script src="/scrips/app.js" is:inline></script>

    <script>
  if (import.meta.env.PROD && 'serviceWorker' in navigator) {
    
    // 1. Registro optimizado inmediato
    const registrarSW = () => {
      navigator.serviceWorker.register('/sw.js')
        .then(() => console.log('SW registrado correctamente'))
        .catch(err => console.log('Error en SW: ', err));
    };

    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      registrarSW();
    } else {
      window.addEventListener('load', registrarSW);
    }

    // 2. Escuchar el progreso enviado desde el sw.js
    navigator.serviceWorker.addEventListener('message', event => {
      if (event.data && event.data.type === 'PWA_DESCARGA_PROGRESO') {
        const barraFlotante = document.getElementById('pwa-floating-bar');
        const textoPorcentaje = document.getElementById('pwa-text-percentage');
        const rellenoBarra = document.getElementById('pwa-progress-fill');
        const textoArchivo = document.getElementById('pwa-file-name');

        if (barraFlotante && textoPorcentaje && rellenoBarra) {
          // Hacemos visible la barra al recibir el primer dato
          barraFlotante.style.display = 'block';
          
          const progreso = event.data.progress;
          textoPorcentaje.innerText = `${progreso}%`;
          rellenoBarra.style.width = `${progreso}%`;

          // Opcional: Muestra de forma limpia qué archivo se está bajando
          if (textoArchivo && event.data.file) {
            const nombreLimpio = event.data.file.split('/').pop() || 'procesando...';
            textoArchivo.innerText = `Descargando: ${nombreLimpio}`;
          }

          // Al llegar al 100%, notificamos y ocultamos elegantemente
          if (progreso === 100) {
            if (textoArchivo) textoArchivo.innerText = '¡Contenido listo para usar sin internet!';
            setTimeout(() => {
              barraFlotante.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
              barraFlotante.style.opacity = '0';
              barraFlotante.style.transform = 'translateY(20px)';
                setTimeout(() => { barraFlotante.style.display = 'none'; }, 600);
            }, 3500); // Se queda visible 3.5 segundos para informar al usuario
          }
        }
      }
    });
  }
</script>

<style>
  .barra-flotante{
    display: none; 
    position: fixed; 
    bottom: 80px; 
    right: 20px; 
    background: #121212; 
    color: #ffffff; 
    padding: 16px; 
    border-radius: 8px; 
    box-shadow: 0 4px 20px rgba(0,0,0,0.6);
     z-index: 9999;
      border: 1px solid #2e7d32; 
      min-width: 260px; 
      font-family: 'Lato', sans-serif;"
  }
</style>
</html>
