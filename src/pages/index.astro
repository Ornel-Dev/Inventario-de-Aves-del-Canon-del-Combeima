---
import Header from "../componentes/Header.astro";
import Btnendemica from "../componentes/btn-endemica.astro";
import Btnaves from "../componentes/btn-aves.astro";
import Ruta from "../componentes/rutas-targ.astro";
import Footer from "../componentes/footer.astro";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans+Flex:opsz,wght@6..144,1..1000&family=Google+Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&family=Lexend:wght@100..900&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"/>
    <link rel="stylesheet" href="/styles/style.css" />
    <link rel="manifest" href="/manifest.json" />
    <title>Áurea | Inventario de Aves del Cañon del Combeima</title>
  </head>
  <body>
    <!-- Usamos el componente como si fuera una etiqueta HTML personalizada -->
     
    <Header />

    <main>
      <section class="seccion-principal imagen-fondo">
        <div class="contenedor-principal contenido">

          <h1>Inventario de Aves del Cañon del Combeima</h1>
          <div>

          <Btnendemica />
          </div>

          <i>Colibrí Cabecicastaño<br>Anthocephala berlepschi</i>
        </div>
      </section>

      <section class="contenedor-principal rutas">
        <Btnaves />

        <div class="rutas-titulo">
          <h2>Rutas de avistamiento</h2>
          <a href="#">Ver Todas</a>
        </div>
        <div class="rutas">
          <Ruta />
        </div>

        <div id="inline-install-container" class="hidden inline-install">
  <p>
    ¿Quieres consultar el inventario sin señal? 
    <button id="inline-install-btn" class="text-btn">Instala la app aquí</button>
  </p>
</div>
      </section>
      <!-- MENSAJE FLOTANTE -->
     <div id="pwa-barra-flotante">
  <div class="pwa-encabezado">
    <span class="pwa-titulo">Modo Offline</span>
    <span id="pwa-texto-porcentaje">0%</span>
  </div>
  <div class="pwa-barra-fondo">
    <div id="pwa-barra-relleno"></div>
  </div>
  <p id="pwa-nombre-archivo"></p>
</div>



      <footer>

        <Footer />
      </footer>
    </main>

  </body>
    <script src="/scrips/app.js" is:inline></script>

<script>
  if (import.meta.env.PROD && 'serviceWorker' in navigator) {
    
    // 1. Registro optimizado inmediato
    const registrarSW = () => {
      navigator.serviceWorker.register('/sw.js')
        .then(() => console.log('SW registrado correctamente'))
        .catch(err => console.log('Error en SW: ', err));
    };

    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      registrarSW();
    } else {
      window.addEventListener('load', registrarSW);
    }

    // 2. Escuchar el progreso enviado desde el sw.js
    navigator.serviceWorker.addEventListener('message', event => {
      if (event.data && event.data.type === 'PWA_DESCARGA_PROGRESO') {
        const barraFlotante = document.getElementById('pwa-barra-flotante');
        const textoPorcentaje = document.getElementById('pwa-texto-porcentaje');
        const rellenoBarra = document.getElementById('pwa-barra-relleno');
        const textoArchivo = document.getElementById('pwa-nombre-archivo');

        if (barraFlotante && textoPorcentaje && rellenoBarra) {
          // Hacemos visible la barra al recibir el primer progreso
          barraFlotante.style.display = 'block';
          
          const progreso = event.data.progress;
          textoPorcentaje.innerText = `${progreso}%`;
          rellenoBarra.style.width = `${progreso}%`;

          // Muestra de forma limpia el nombre del archivo actual
          if (textoArchivo && event.data.file) {
            const nombreLimpio = event.data.file.split('/').pop() || 'procesando...';
            textoArchivo.innerText = `Descargando: ${nombreLimpio}`;
          }

          // Al completarse el 100%, informamos y ocultamos con animación
          if (progreso === 100) {
            if (textoArchivo) textoArchivo.innerText = '¡Áurea está lista para usarse sin internet!';
            
            setTimeout(() => {
              barraFlotante.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
              barraFlotante.style.opacity = '0';
              barraFlotante.style.transform = 'translateY(20px)';
              
              // Esperamos a que termine la animación para quitarla del flujo de renderizado
              setTimeout(() => { 
                barraFlotante.style.display = 'none'; 
              }, 600);
            }, 3500);
          }
        }
      }
    });
  }
</script>

<style>
  body{
    margin-bottom: 10rem;
  }
  #pwa-barra-flotante {
    display: none;
    position: fixed;
    bottom: 7.5rem;
    right: 1.9rem;
    background: #121212;
    color: #ffffff;
    padding: 16px;
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.6);
    z-index: 9999;
    border: 1px solid #2e7d32;
    min-width: 260px;
    font-family: 'Lato', sans-serif;
  }

  .pwa-encabezado {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .pwa-titulo {
    font-size: 13px;
    font-weight: bold;
    letter-spacing: 0.5px;
  }

  #pwa-texto-porcentaje {
    color: #2e7d32;
    font-weight: bold;
    font-size: 14px;
  }

  .pwa-barra-fondo {
    width: 100%;
    background: #222222;
    height: 6px;
    border-radius: 4px;
    overflow: hidden;
  }

  #pwa-barra-relleno {
    width: 0%;
    background: #2e7d32;
    height: 100%;
    transition: width 0.2s ease;
  }

  #pwa-nombre-archivo {
    margin: 6px 0 0 0;
    font-size: 10px;
    color: #777777;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 230px;
  }



  .inline-install {
    text-align: center;
    padding: 2rem 1rem;
    font-size: 0.95rem;
    color: #4b5563; /* Un gris oscuro sutil */
  }
  
  .text-btn {
    background: none;
    border: none;
    color: #2563eb; /* Color de enlace clásico o ajusta al color primario de Áurea */
    text-decoration: underline;
    font-weight: 600;
    cursor: pointer;
    padding: 0;
    font-size: inherit;
    font-family: inherit;
  }

  .text-btn:hover {
    color: #1e40af;
  }

  .hidden {
    display: none;
  }
</style>

</html>
