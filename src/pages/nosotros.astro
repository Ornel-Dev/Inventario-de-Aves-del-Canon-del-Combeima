<h1>Nosotros</h1>
 <svg height="200" width="200" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
	<path d="M10 14a2 2 0 1 1-4 0a2 2 0 0 1 4 0Zm1.78-8.841a.75.75 0 0 0-1.06 0l-1.97 1.97V.75a.75.75 0 0 0-1.5 0v6.379l-1.97-1.97a.75.75 0 0 0-1.06 1.06l3.25 3.25L8 10l.53-.53l3.25-3.25a.75.75 0 0 0 0-1.061Z" fill="currentColor"/>
</svg>
