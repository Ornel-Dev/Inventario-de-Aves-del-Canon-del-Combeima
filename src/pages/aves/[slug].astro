</html>

<style>
  main {
    margin-bottom: 30rem;
  }
  /*Globales  */
  .detalle-ave {
    max-width: 90%;
  }
  h1 {
    font-size: 3rem;
    margin-bottom: 0rem;
    line-height: 0.4;
  }
  i {
    font-size: 2rem;
  }
  p {
    font-size: 1.6rem;
  }
  .nombreIngles {
    font-size: 1.8rem;
    margin: 0;
    line-height: 0.3;
  }

  /* Contenedor de la foto */

  .detalle-ave img {
    width: 100%;
    border-radius: 2rem;
  }

  .contenedor-foto {
    position: relative;
    height: auto;
    width: 100%;
  }

  /*  Estilos para el incono de estado*/

  .estado {
    padding: 0.7rem;
    border-radius: 50%;
    font-weight: bold;
    font-size: 1.2rem;
    position: absolute;
    top: 83%;
    right: 1rem;
  }
  .estado-lc {
    background-color: rgb(1, 145, 1);
    color: #ffff;
  }
  .fondo-lc {
    background-color: rgb(210, 255, 210);
  }
  .estado-nt {
    background-color: rgb(21, 248, 21);
    color: black;
  }
  .estado-vu {
    background-color: #ffe600;
    color: black;
  }
  .fondo-vu {
    background-color: hsl(68, 100%, 89%);
  }
  .estado-en {
    background-color: rgb(255, 102, 0);
    color: black;
  }
  .fondo-en {
    background-color: rgb(255, 220, 197);
  }
  .estado-cr {
    background-color: rgb(255, 0, 0);
  }

  /* Estilo para la tarjeta */
  .target {
    margin-top: 3rem;
    border: 0.1rem solid #615e5e;
    border-radius: 2rem;
    height: auto;
    /* ELIMINAR */
  }
  .contenido-target {
    padding: 2rem;
    margin: 0 auto;
  }
  .piso {
    display: flex;
    align-items: center;
    font-size: 1.2rem;
  }

  .piso svg {
    width: 2.4rem;
    height: 2.4rem;
  }
  /* especificos */

  .T-habitat {
    margin: 0;
    font-size: 1.3rem;
    font-weight: bold;
  }
  .t-habitat {
    background-color: #e0e0e0;
  }
  /* Estilo para la tarjeta de ESTADO*/
  .big-estado {
    font-size: 2.5rem;
    font-weight: 900;
    padding: 1rem;
    border-radius: 50%;
    margin-bottom: 1rem;
  }
  .t-estado {
    width: 100%;
  }
  .content-estado {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }
  .content-estado p {
    margin: 0.3rem;
  }
  .titulo-uicn {
    font-size: 1.2rem;
  }
  .contenido-uicn {
    font-weight: 800;
  }

  .big-estado-vu {
    background-color: red;
  }
  /* Estilo para la tarjeta de DESCRICIÓN*/
  .description {
  }
  .description svg {
    width: 2.4rem;
    height: inherit;
  }
  .description h1 {
    font-size: 2rem;
    display: flex;
    align-items: center;
  }
  .dato {
    border: 0.1rem solid rgb(211, 211, 211);
    border-radius: 1rem;
    border-left: 0.3rem solid #ff6600;
    background-color: #fce4d5;
  }
  .dato p {
    padding: 1rem;
    margin: 0;
  }

  /* Estilo para la tarjeta de Audio*/
  /* header  Audio*/
  .t-audio{
    background-color: rgb(27, 67, 50);

  }
  .header-audio {
    display: flex;
    justify-content: space-between;
    color: #ffff;

      }
  .header-audio svg {
    width: 4.8rem;
    height: 4.8rem;
  }
  .header-audio h2 {
    font-size: 2rem;
    margin: 0;
  }
  .header-audio p{
    font-size: 1.2rem;
    margin-top: .5rem;
    margin-bottom: 0;
    color: #bed4c0;
  }

  .iconos-audio{
    margin-top: 2rem;
    margin-bottom: 2rem;
  }



  /* ESTILOS DEL DIV ADVERTENCIA */
  .advertencia-audio{
   display: flex;
  align-content: flex-start;
  column-gap: 1rem;
  border: .1rem solid rgb(69, 92, 82);
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 1rem;
  padding: 1rem;

  }
  .advertencia-audio svg{
    
width: 9.4rem;
height: 4rem;
color: rgb(218, 15, 15);
  }

  .advertencia-audio p{
    margin: 0;
    color: #d3e4d4;

  }


  /* 4. Dale el estilo que quieras a tu botón */

  .btn-audio {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background-color: #2e7d32; /* Un verde ecológico */
    color: white;
    border: none;
    width: 4.8rem;
    height: 4.8rem;
    border-radius: 50%;
    font-weight: bold;
    cursor: pointer;
    transition:
      background-color 0.2s,
      transform 0.1s;
  }

  .btn-audio:hover {
    background-color: #1b5e20;
  }

  .btn-audio:active {
    transform: scale(0.98);
  }

  /* Estilo opcional por si quieres cambiar el color al estar activo */
  .btn-audio.reproduciendo {
    background-color: #ff0000; /* Rojo al pausar, por ejemplo */
  }
</style>

<script>
  // 3. Lógica para controlar el reproductor
  const audio = document.getElementById("audio-ave") as HTMLAudioElement;
  const boton = document.getElementById("btn-reproducir");
  const icono = boton?.querySelector(".icono");

  if (audio && boton && icono) {
    boton.addEventListener("click", () => {
      if (audio.paused) {
        audio.play();
        icono.textContent = "⏸"; // Cambia el icono a Pausa
        boton.classList.add("reproduciendo");
      } else {
        audio.pause();
        icono.textContent = "▶"; // Cambia el icono a Play
        boton.classList.remove("reproduciendo");
      }
    });

    // Resetear el botón automáticamente si el audio termina de reproducirse
    audio.addEventListener("ended", () => {
      icono.textContent = "▶";
      boton.classList.remove("reproduciendo");
    });
  }
</script>
