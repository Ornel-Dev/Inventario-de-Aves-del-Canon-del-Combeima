                fill="none"
                stroke="#0066cc"
                stroke-linejoin="round"
                stroke-width="4"
                ><path d="m18 10l14 28H4l14-28Z"></path><path
                  stroke-linecap="round"
                  d="m28 29l5.647-7L44 38H32M12 22h12m-10-4l-4 8m12-8l4 8"
                ></path></g
              ></svg
            >
            <span>Piso Termico: {ave.Piso}</span>
          </div>
        </div>
      </section>

      {/* Estilo para la tarjeta DE ESTADO */}
