<style>
  .footer {
    display: flex;
    justify-content: space-evenly;
    background-color: #cccccc;
    border-top-left-radius: 2rem;
    border-top-right-radius: 2rem;
    height: 5rem;
    padding: 0.5rem;
    height: auto;
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
  }

  .items-footer {
    font-size: 1.3rem;
    justify-content: center;
    align-items: center;
    display: flex;
    flex-direction: column;
    padding: 1rem;
    height: 6rem;
    width: 6rem;
  }
  .items-footer p {
    margin: 0rem;
  }

  a {
    text-decoration: none;
    color: #000000;
  }

  svg {
    color: #1b4332;
  }

  /* Estilos minimalistas de ejemplo */
  .install-banner {
    position: fixed;
    bottom: 80px; /* Ajusta según el alto de tu footer real */
    left: 50%;
    transform: translateX(-50%);
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    border-radius: 8px;
    padding: 16px;
    z-index: 50;
    max-width: 90%;
    width: 400px;
    transition: opacity 0.3s ease;
  }
  .banner-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-size: 0.9rem;
    color: #374151;
  }
  .banner-actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
  }
  .hidden {
    display: none;
  }
  .btn-primary {
    background-color:var(--verde-oscuro);
    color: white;
    border: none;
    padding: 6px 12px;
    border-radius: 4px;
    cursor: pointer;
  }
  .btn-secondary {
    background: transparent;
    border: none;
    color: #6b7280;
    cursor: pointer;
    padding: 6px 8px;
  }
</style>

<script>
  // 1. Le explicamos a TypeScript la estructura del evento de instalación
interface BeforeInstallPromptEvent extends Event {
  readonly platforms: Array<string>;
  readonly userChoice: Promise<{
    outcome: 'accepted' | 'dismissed';
    platform: string;
  }>;
  prompt(): Promise<void>;
}

// 2. Tipamos la variable y la inicializamos como null
let deferredPrompt: BeforeInstallPromptEvent | null = null;
const banner = document.getElementById('pwa-install-banner');
const btnInstall = document.getElementById('btn-install-pwa');
const btnClose = document.getElementById('btn-close-banner');

// 3. Escuchamos el evento de instalación nativo
window.addEventListener('beforeinstallprompt', (e) => {
  // Evitamos el mini-infobar nativo de Chrome inmediatamente
  e.preventDefault();
  
  // Guardamos el evento para poder dispararlo luego con el botón
  deferredPrompt = e as BeforeInstallPromptEvent;

  // MODIFICACIÓN: Retrasamos la aparición del banner 10 segundos (10000 milisegundos)
  setTimeout(() => {
    // Verificamos localStorage JUSTO AQUÍ dentro por si el estado cambió en esos 10 segundos
    const bannerDismissed = localStorage.getItem('aurea_pwa_dismissed') === 'true';

    // Si el usuario no lo ha cerrado antes y el banner existe, lo mostramos
    if (!bannerDismissed && banner) {
      banner.classList.remove('hidden');
    }
  }, 10000); // 10000 ms = 10 segundos
});

// 4. Acción de Instalar
if (btnInstall) {
  btnInstall.addEventListener('click', async () => {
    // Ocultamos el banner inmediatamente por UX
    banner?.classList.add('hidden');
    
    if (deferredPrompt) {
      // Mostramos el prompt nativo de instalación
      deferredPrompt.prompt();
      
      // Esperamos la respuesta del usuario (Aceptó o Canceló)
      const { outcome } = await deferredPrompt.userChoice;
      
      if (outcome === 'accepted') {
        console.log('Instalación aceptada');
        // Si acepta, ya no necesitamos mostrar el banner en el futuro
        localStorage.setItem('aurea_pwa_dismissed', 'true');
      }
      
      // Limpiamos la variable
      deferredPrompt = null;
    }
  });
}

// 5. Acción de Cerrar (Dismiss)
if (btnClose) {
  btnClose.addEventListener('click', () => {
    banner?.classList.add('hidden');
    // Guardamos la preferencia en el navegador para que no vuelva a salir al cambiar de página
    localStorage.setItem('aurea_pwa_dismissed', 'true');
  });
}

// 6. Escuchar si se instaló exitosamente
window.addEventListener('appinstalled', () => {
  if (banner) banner.classList.add('hidden');
  localStorage.setItem('aurea_pwa_dismissed', 'true');
  deferredPrompt = null;
});
</script>
