---
const rutaInfo = [
  {
    name: "Cascada La Plata",
    altura: "2.200 msnm",
    img: "/imgs/cascadalaplata.avif",
  },
  {
    name: "Ruta de la Fruta",
    altura: "1.800 msnm",
    img: "/imgs/rutafruta.avif",
  },
  {
    name: "Termales el Rancho",
    altura: "2.800 msnm",
    img: "/imgs/ranchotermales.avif",
  },
];
---

{
  rutaInfo.map((ruta) => (
<div
  class="ruta"
  style={{
    backgroundImage: `linear-gradient(to bottom, rgba(0,0,0,0.0), rgba(0,0,0,0.6)), url(${ruta.img})`
  }}
>
<div class="info">

      <h3>{ruta.name}</h3>
      <p>Altura: {ruta.altura}</p>
        </div>
    </div>

  ))
}

<style>
  .ruta {
    width: 100%;
    height: 30rem; /* Ajusté el alto para que sea visible */
    background-size: cover;
    background-position: center;
    color: white; /* Para que el texto sea legible sobre la imagen */
    border-radius: 1rem;
    margin-bottom: 2rem;
    display: flex;
    box-shadow: -2px 18px 35px -7px rgba(0,0,0,0.36);

  }
  .info {
    display: flex;
    flex-direction: column;
    justify-content: end;
    margin-left: 2rem;

    
  }

  h3{
    font-size: 2rem;
    margin-bottom: .5rem;
  }


  .ruta .info p {
    font-size: 1.2rem;
    font-weight: 400;
    margin: 0rem 0rem 2rem;


  }


</style>
