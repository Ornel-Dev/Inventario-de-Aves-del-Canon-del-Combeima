---


<div class="galeria">
  {
    listAvesTarget.map((target) => (
      <a href={`/aves/${target.slug}`}>
        <div
          class="tarjetaAves"
          style={`background-image: linear-gradient(to bottom, rgba(0,0,0,0.0), rgba(0,0,0,0.6)), url(${target.Imagen})`}
        >
        <div class="info">
            <div class="nombres">

          <p class="nombre">{target.nombreComun}</p>
          <i class="nombreCientifico">{target.nombreCientifico}</i>

            </div>
          <div class="estado">
         <p class:list={["estado-logo", `estado-${target.Estado.toLowerCase()}`]}>
  {target.Estado}
</p>
          </div>
        </div>


      </div>
      </a>

    ))
  }
</div>

<style>
  .galeria {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-gap: 1rem;
    margin-bottom: 12rem;
  }

  @media (min-width:768px) {
    div.galeria{
    grid-template-columns: repeat(4, 1fr);

    }
   
  }


  .tarjetaAves {
    width: 100%;
    height: 20rem;
    background-position: center;
    background-size: cover;
    border-radius: 1rem;
    display: flex;
    flex-direction: column;
    justify-content: end;
    color: #fff;
    padding: 1rem;
    
  }

  .nombre,
  .nombreCientifico {
    padding-left: 2rem;
  }
  .nombre {
    margin: 0;
    font-size: 1.3rem;
  }
  .nombreCientifico {
    font-size: 1rem;
    margin: 0;

  }
 
  .info{
    display: flex;
    justify-content: space-between;
    height: fit-content;
  }
  .estado{
display: flex;
align-items: center;
padding-right: 1rem;
}
.estado-logo{
    padding: .3rem;
    border-radius: 50%;
    font-weight: bold;
}
.estado-lc{
        background-color: green ;

}
